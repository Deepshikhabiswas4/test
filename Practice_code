def insert_tracker_record(
        spark,
        file_name,
        file_date):
    """
    Creates tracker row before processing.
    """

    data = [
        (
            file_name,
            file_date,
            "NOT_PROCESSED",
            None,
            None
        )
    ]

    columns = [
        "FILE_NAME",
        "FILE_DATE",
        "STATUS",
        "PROCESSED_TS",
        "ERROR_MESSAGE"
    ]

    df = spark.createDataFrame(
        data,
        columns
    )

    write_oracle(
        df,
        "BGL_FILE_TRACKER"
    )
