from concurrent.futures import ThreadPoolExecutor, as_completed

def process_file_wrapper(file_name):
    try:
        spark = SparkSession.getActiveSession()
        value = process_single_file_dynamic(spark, file_name)

        return {
            "file_name": file_name,
            "value": value,
            "error": None
        }
    except Exception as e:
        return {
            "file_name": file_name,
            "value": None,
            "error": str(e)
        }


def process_ready_files(batch_df, batch_id):
    global typeToRead, run_id, process_run_id, failedFiles, count_holder

    print(f"Batch {batch_id} received")

    spark = batch_df.sparkSession

    # ✅ Filter READY files
    ready_files = [
        row["file_name"]
        for row in batch_df
        .filter(col("final_status") == "READY")
        .select("file_name")
        .collect()
    ]

    if not ready_files:
        print("No READY files in this batch.")
        return

    print(f"Processing {len(ready_files)} files in parallel")

    producer = Producer({"bootstrap.servers": get_kafka_ip()})

    # ✅ Parallel execution
    max_workers = min(8, len(ready_files))  # safe limit

    with ThreadPoolExecutor(max_workers=max_workers) as executor:
        futures = {
            executor.submit(process_file_wrapper, file): file
            for file in ready_files
        }

        for future in as_completed(futures):
            result = future.result()
            file_name = result["file_name"]

            try:
                if result["error"]:
                    raise Exception(result["error"])

                message = {
                    "file_name": file_name.replace(".gz", ""),
                    "value": result["value"],
                    "etl_date": get_etl_date(spark).strftime("%d-%m-%Y")
                }

                producer.produce(
                    topic="allfiletodatalake",
                    value=json.dumps(message)
                )

            except Exception as e:
                file_code = file_name.split("_")[0]
                failedFiles.append(file_code)

                log_etl(
                    spark,
                    process_run_id,
                    f"{typeToRead}_error_files",
                    3,
                    f"Error in file {file_name}"
                )

                count_holder[0] += 1

    producer.flush()

    # ✅ Final completion check
    check_and_stop_spark(
        spark,
        typeToRead,
        run_id,
        failedFiles,
        count_holder,
        get_etl_date(spark)
    )
