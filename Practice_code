def mark_processed(
        spark,
        file_name):
    """
    Mark file as successfully processed.
    """

    update_sql = f"""
        UPDATE BGL_FILE_TRACKER
           SET STATUS = 'PROCESSED',
               PROCESSED_TS = SYSTIMESTAMP,
               ERROR_MESSAGE = NULL
         WHERE FILE_NAME = '{file_name}'
    """

    execute_query(update_sql)
