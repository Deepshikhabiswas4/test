def get_delta_path_by_file_type(file_type):
    """
    Returns delta lake path based on FILE TYPE.
    """

    HDFS_BASE = get_hdfs_base()
    file_type = file_type.upper()

    if file_type == "GLIF":
        return f"{HDFS_BASE}/data-lake/allData/GLIF"

    elif file_type == "INV":
        return f"{HDFS_BASE}/data-lake/allData/INVTOGL"

    elif file_type == "BOR":
        return f"{HDFS_BASE}/data-lake/allData/BORTOGL"

    elif file_type == "GLCCTA":
        return f"{HDFS_BASE}/data-lake/allData/GLCCCTA"

    elif file_type == "GLCCGEN":
        return f"{HDFS_BASE}/data-lake/allData/GLLCGEN"

    else:
        raise Exception(f"Unsupported FILE TYPE: {file_type}")
