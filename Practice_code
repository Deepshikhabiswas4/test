if check_MonthEnd():

    logger.info("=== Month-end provision processing started ===")

    try:

        BATCH_ID_LITERAL = get_batch_id(spark)

        provision_df = process_provision_data(
            RUN_ID,
            BATCH_ID_LITERAL
        )

        reversal_df = reverse_provision(
            TRANSACTIONS,
            BATCH_ID_LITERAL
        )

        provision_txn_df = (
            reversal_df
            .unionByName(
                provision_df,
                allowMissingColumns=True
            )
            .withColumn(
                "TRANSACTION_DATE",
                F.to_date(F.lit(etl_plus_1_str))
            )
        )

        write_oracle(
            provision_txn_df,
            TRANSACTIONS
        )

        logger.info(
            f"Provision/Reversal posted successfully for {etl_plus_1_str}"
        )

    except Exception as e:

        logger.error(
            f"Provision processing failed: {e}"
        )

        spark.stop()
        sys.exit(1)
