def mark_failed(
        spark,
        file_name,
        error_message):
    """
    Mark file as failed.
    """

    error_message = (
        str(error_message)
        .replace("'", " ")
    )

    update_sql = f"""
        UPDATE BGL_FILE_TRACKER
           SET STATUS = 'FAILED',
               PROCESSED_TS = SYSTIMESTAMP,
               ERROR_MESSAGE = '{error_message}'
         WHERE FILE_NAME = '{file_name}'
    """

    execute_query(update_sql)
