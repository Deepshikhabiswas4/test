def process_provision_data(BATCH_ID_LITERAL=None):

    # ===================== DATES =====================
    etl_date = get_etl_date(spark)
    etl_str = etl_date.strftime("%Y-%m-%d")

    RUN_ID = get_run_id(spark, etl_str, "GLIF")
    logger = setup_logger("GLIF", RUN_ID, etl_str)

    logger.info(f"ETL_DATE : {etl_date}")

    # =========================================================
    # READ GLIF RAW DELTA (DATALAKE)
    # =========================================================
    GLIF_DELTA_PATH = get_delta_path_by_file_type("glif", etl_str)

    df_raw = spark.read.format("delta").load(GLIF_DELTA_PATH)

    # =========================================================
    # ONLY PROVISION FILES (GLIFPRI & GLIFPRB)
    # =========================================================
    df_raw = df_raw.filter(
        (F.lower(F.col("file_name")).startswith("glifpri")) |
        (F.lower(F.col("file_name")).startswith("glifprb"))
    )

    logger.info("Filtered only provision files")

    # =========================================================
    # CREATE ID USING PARSED COLUMNS (NO SUBSTRING ANYMORE)
    # =========================================================
    df_processed = df_raw.withColumns({
        "Id": F.concat(F.col("BRANCH_CODE"), F.col("CURRENCY"), F.col("CGL")),
        "currency_code": F.col("CURRENCY")
    })

    # =========================================================
    # AMOUNT SELECTION (FOREIGN vs INR)
    # =========================================================
    df_clean = df_processed.withColumns({
        "Amount_raw": F.when(
            F.col("currency_code") != "INR",
            F.col("FOREIGN_AMOUNT")
        ).otherwise(F.col("AMOUNT"))
    })

    # =========================================================
    # SIGNED AMOUNT LOGIC (ACCOUNTING SIGN CONVERSION)
    # =========================================================
    df_clean = df_clean.withColumns({
        "Amount_base": substring(col("Amount_raw"), 1, 16),
        "sign_char": substring(col("Amount_raw"), 17, 1)
    })

    digit_map = create_map(
        lit('1'), lit('1'), lit('2'), lit('2'), lit('3'), lit('3'),
        lit('4'), lit('4'), lit('5'), lit('5'), lit('6'), lit('6'),
        lit('7'), lit('7'), lit('8'), lit('8'), lit('9'), lit('9'),
        lit('0'), lit('0'),
        lit('p'), lit('0'), lit('q'), lit('1'), lit('r'), lit('2'),
        lit('s'), lit('3'), lit('t'), lit('4'), lit('u'), lit('5'),
        lit('v'), lit('6'), lit('w'), lit('7'), lit('x'), lit('8'),
        lit('y'), lit('9')
    )

    df_with_signed_amount = df_clean.withColumns({
        "last_digit": digit_map.getItem(col("sign_char")),
        "sign": when(
            col("sign_char").isin(['p','q','r','s','t','u','v','w','x','y']),
            -1
        ).otherwise(1)
    })

    df_with_signed_amount = df_with_signed_amount.withColumn(
        "Amount_decimal_str",
        concat(col("Amount_base"), col("last_digit"))
    )

    df_final = df_with_signed_amount.withColumns({
        "Amount_final": (col("Amount_decimal_str").cast(DecimalType(25,4)) / 1000) * col("sign")
    })

    # =========================================================
    # DEBIT / CREDIT SPLIT
    # =========================================================
    df_with_signed_amount = df_final.withColumns({
        "Amountpve": when(col("Amount_final") > 0, col("Amount_final")).otherwise(0),
        "Amountnve": when(col("Amount_final") < 0, col("Amount_final")).otherwise(0)
    })

    df_agg = df_with_signed_amount.groupBy("Id").agg(
        F.sum(F.col("Amountpve")).alias("DEBIT_AMOUNT"),
        F.sum(F.col("Amountnve")).alias("CREDIT_AMOUNT"),
        F.count(F.col("Id")).alias("TRANSACTION_COUNT")
    )

    # =========================================================
    # JOURNAL CREATION
    # =========================================================
    df_mapped = df_agg.withColumns({
        "BATCH_ID": lit(BATCH_ID_LITERAL).cast(StringType()),
        "JOURNAL_ID": lit(None).cast(StringType()),
        "BRANCH_CODE": substring(col("Id"), 1, 5),
        "CURRENCY": substring(col("Id"), 6, 3),
        "CGL": substring(col("Id"), 9, 10),
        "NARRATION": concat(lit("Provision for - "), date_format(to_date(lit(etl_str)), "MMMyyyy")),
        "SOURCE_FLAG": lit("V").cast(StringType())
    })

    provision_df = df_mapped.select(
        "BATCH_ID",
        "JOURNAL_ID",
        "BRANCH_CODE",
        "CURRENCY",
        "CGL",
        "NARRATION",
        "DEBIT_AMOUNT",
        "CREDIT_AMOUNT",
        "TRANSACTION_COUNT",
        "SOURCE_FLAG"
    )

    logger.info("Provision dataframe created successfully")

    return provision_df


