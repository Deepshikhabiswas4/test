def invtogl(spark):
    try:
        
        
        try:
            log_etl(spark, process_run_id, "invtogl_filereading_started",1,"INVTOGL File Reading Started")
            df_raw = spark.read.format("delta").load(INV_FILES)
        except Exception as e:
            log_etl(spark, process_run_id, "invtogl_filereading_started",3,"ERROR IN READING  INVTOGL FILES")
            spark.stop()
            exit()
        
        
        id_col = expr("substring(value, 200, 18)")
        amount_str = expr("substring(value, 30, 17)")
        value_type = expr("substring(value, 47, 1)")
        df_final = df_raw.select(
            id_col.alias("Id"),
            when(value_type == "-", 1 * trim(amount_str).cast(DecimalType(25, 4)) / 1000)
            .otherwise( -1 * trim(amount_str).cast(DecimalType(25, 4)) / 1000)
            .alias("Amount"),
        )
        return df_final
    except Exception as e:
        # print(f"Error processing invtogl: {e}")
        logger.info(f"Error processing invtogl", exc_info=True)
        log_etl(spark, process_run_id, "invtogl_filereading_started",3,"ERROR IN READING  INVTOGL FILES")
        spark.stop()
        exit()
        raise

