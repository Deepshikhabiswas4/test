def is_processed(
        spark,
        file_name):
    """
    Check if file is already processed.
    """

    query = f"""
    (
        SELECT COUNT(*) AS CNT
        FROM BGL_FILE_TRACKER
        WHERE FILE_NAME = '{file_name}'
          AND STATUS = 'PROCESSED'
    )
    """

    tracker_df = read_oracle(
        spark=spark,
        table=query
    )

    return (
        tracker_df.collect()[0]["CNT"] > 0
    )
