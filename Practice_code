def insert_tracker_record(
        spark,
        file_name,
        file_date):
    """
    Insert new file into tracker table
    before processing starts.
    """

    tracker_data = [
        (
            file_name,
            file_date,
            "NOT_PROCESSED",
            None,
            None
        )
    ]

    tracker_columns = [
        "FILE_NAME",
        "FILE_DATE",
        "STATUS",
        "PROCESSED_TS",
        "ERROR_MESSAGE"
    ]

    tracker_df = spark.createDataFrame(
        tracker_data,
        tracker_columns
    )

    write_oracle(
        tracker_df,
        "BGL_FILE_TRACKER"
    )
