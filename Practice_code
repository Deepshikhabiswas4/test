# =========================================================
def reverse_provision(TRANSACTIONS, BATCH_ID_LITERAL):

    prev_month_end = check_Previous_MonthEnd()
    prev_month_end_str = prev_month_end.strftime("%Y-%m-%d")

    sql_Query = f"""(
        select * from {TRANSACTIONS}
        where source_flag = 'V'
        and TRANSACTION_DATE = TO_DATE('{prev_month_end_str}', 'yyyy-mm-dd')
    ) t"""

    last_month_provision_df = read_oracle(spark, sql_Query)

    final_df = last_month_provision_df.select(
        col("JOURNAL_ID"),
        col("BRANCH_CODE"),
        col("CURRENCY"),
        col("CGL"),
        concat(
            lit("Provision Reversal for - "),
            date_format(lit(prev_month_end_str), "MMMyyyy")
        ).alias("NARRATION"),
        (-col("CREDIT_AMOUNT")).alias("DEBIT_AMOUNT"),
        (-col("DEBIT_AMOUNT")).alias("CREDIT_AMOUNT"),
        col("TRANSACTION_COUNT"),
        col("SOURCE_FLAG")
    ).withColumn("BATCH_ID", F.lit(BATCH_ID_LITERAL))

    return final_df
